# Groq LLM
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=gemma2-9b-it
GROQ_FALLBACK_MODEL=llama-3.3-70b-versatile

# Database (Postgres). MySQL also supported via mysql+pymysql:// URL.
DATABASE_URL=postgresql+psycopg2://hcp_user:hcp_pass@localhost:5432/hcp_crm

# CORS
FRONTEND_ORIGIN=http://localhost:5173
